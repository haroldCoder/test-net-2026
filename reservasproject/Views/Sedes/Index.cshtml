@{
    ViewData["Title"] = "Lugares Disponibles";
}

<!-- Importar Google Fonts y iconos de Bootstrap -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<!-- Hoja de estilos separada -->
<link rel="stylesheet" href="~/css/sedes.css" asp-append-version="true" />

<div class="container py-4">
    <!-- Hero Header -->
    <div class="places-hero">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 class="display-5 fw-extrabold mb-2" style="font-weight: 800;">Explora Nuestros Destinos</h1>
                <p class="lead mb-0 opacity-90">Encuentra el lugar perfecto para tu descanso o estadía de negocios.</p>
            </div>
            <div class="col-lg-4 text-lg-end d-none d-lg-block">
                <i class="bi bi-compass" style="font-size: 4.5rem; opacity: 0.2;"></i>
            </div>
        </div>
    </div>

    <!-- Search and Filters Section -->
    <div class="search-filter-wrapper">
        <form id="availabilityForm" onsubmit="searchAvailability(event)" class="row g-3 align-items-end mb-4">
            <div class="col-lg-3 col-md-6">
                <label class="form-label text-muted fw-bold small"><i class="bi bi-search"></i> Buscar Sitio/Ciudad</label>
                <div class="search-input-group">
                    <i class="bi bi-search"></i>
                    <input type="text" id="searchInput" class="form-control search-input" placeholder="Nombre o ciudad..." />
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <label class="form-label text-muted fw-bold small"><i class="bi bi-calendar-event"></i> Check-In (Entrada)</label>
                <input type="date" id="checkInDate" class="form-control form-control-lg date-input" required />
            </div>
            <div class="col-lg-3 col-md-6">
                <label class="form-label text-muted fw-bold small"><i class="bi bi-calendar-check"></i> Check-Out (Salida)</label>
                <input type="date" id="checkOutDate" class="form-control form-control-lg date-input" required />
            </div>
            <div class="col-lg-2 col-md-4">
                <label class="form-label text-muted fw-bold small"><i class="bi bi-people"></i> Personas</label>
                <select id="guestCount" class="form-select form-select-lg guests-select">
                    <option value="">Cualquiera</option>
                    <option value="1">1 Persona</option>
                    <option value="2">2 Personas</option>
                    <option value="3">3 Personas</option>
                    <option value="4">4 Personas</option>
                    <option value="5">5 Personas</option>
                    <option value="6">6+ Personas</option>
                </select>
            </div>
            <div class="col-lg-1 col-md-2 text-end">
                <button type="submit" class="btn btn-primary btn-lg w-100 search-btn-grad">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </form>
        
        <div class="row pt-3 border-top border-light-subtle">
            <div class="col-md-12 text-md-start">
                <div class="d-flex gap-2 align-items-center flex-wrap">
                    <span class="text-muted fw-bold small me-2"><i class="bi bi-funnel"></i> Filtrar Categoría:</span>
                    <button class="filter-btn active" onclick="filterPlaces('todos', this)">Todos</button>
                    <button class="filter-btn" onclick="filterPlaces('Apartamento', this)">Apartamentos</button>
                    <button class="filter-btn" onclick="filterPlaces('Sede Recreativa', this)">Sedes Recreativas</button>
                    
                    <button id="clearDatesBtn" class="btn btn-outline-danger btn-sm rounded-pill ms-auto d-none" onclick="clearAvailabilitySearch()">
                        <i class="bi bi-x-circle"></i> Limpiar Fechas
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Grid de Tarjetas -->
    <div class="place-grid" id="placesGrid">
        <!-- Cargando / Shimmer placeholders -->
        <div class="text-center py-5 w-100 grid-column-full" id="loadingSpinner">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Cargando lugares...</span>
            </div>
            <p class="mt-3 text-muted">Cargando destinos...</p>
        </div>
    </div>
</div>

<!-- Modal de Detalles y Disponibilidad de Unidades -->
<div class="modal fade" id="sedeDetailsModal" tabindex="-1" aria-labelledby="sedeDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content glass-modal">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-extrabold" id="sedeDetailsModalLabel" style="font-weight: 800; font-size: 1.6rem;"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3" id="sedeDetailsModalBody">
                <!-- Se cargará dinámicamente -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Scripts separados -->
    <script src="~/js/sedes.js" asp-append-version="true"></script>
}
