@{
    ViewData["Title"] = "Lugares Disponibles";
}

<!-- Importar Google Fonts y iconos de Bootstrap -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<!-- Hoja de estilos separada -->
<link rel="stylesheet" href="~/css/sedes.css" asp-append-version="true" />

<div class="container py-4">
    <!-- Hero Header -->
    <div class="places-hero">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 class="display-5 fw-extrabold mb-2" style="font-weight: 800;">Explora Nuestros Destinos</h1>
                <p class="lead mb-0 opacity-90">Encuentra el lugar perfecto para tu descanso o estadía de negocios.</p>
            </div>
            <div class="col-lg-4 text-lg-end d-none d-lg-block">
                <i class="bi bi-compass" style="font-size: 4.5rem; opacity: 0.2;"></i>
            </div>
        </div>
    </div>

    <!-- Search and Filters Section -->
    <div class="search-filter-wrapper">
        <div class="row g-3 align-items-center">
            <div class="col-md-5">
                <div class="search-input-group">
                    <i class="bi bi-search"></i>
                    <input type="text" id="searchInput" class="form-control search-input form-control-lg" placeholder="Buscar por nombre o ciudad..." />
                </div>
            </div>
            <div class="col-md-7 text-md-end">
                <div class="d-flex gap-2 justify-content-md-end flex-wrap">
                    <button class="filter-btn active" onclick="filterPlaces('todos', this)">Todos</button>
                    <button class="filter-btn" onclick="filterPlaces('Apartamento', this)">Apartamentos</button>
                    <button class="filter-btn" onclick="filterPlaces('Sede Recreativa', this)">Sedes Recreativas</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Grid de Tarjetas -->
    <div class="place-grid" id="placesGrid">
        <!-- Cargando / Shimmer placeholders -->
        <div class="text-center py-5 w-100 grid-column-full" id="loadingSpinner">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Cargando lugares...</span>
            </div>
            <p class="mt-3 text-muted">Cargando destinos...</p>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Scripts separados -->
    <script src="~/js/sedes.js" asp-append-version="true"></script>
}
