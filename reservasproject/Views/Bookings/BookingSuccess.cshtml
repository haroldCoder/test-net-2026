@model reservasproject.Models.Reserva
@{
    ViewData["Title"] = "Reserva Exitosa";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow border-0 rounded-4 p-5">
                <div class="mb-4">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
                </div>
                <h1 class="fw-bold text-dark mb-3">¡Reserva Confirmada!</h1>
                <p class="lead text-muted mb-4">
                    Tu reserva ha sido registrada exitosamente con el código <strong>#@Model.Id.ToString("D5")</strong>.
                    Hemos guardado tu cupo para tu viaje.
                </p>
                <div class="bg-light rounded-3 p-3 mb-4 text-start">
                    <div class="row text-center">
                        <div class="col-6 border-end">
                            <small class="text-muted text-uppercase fw-bold">Fecha de Llegada</small>
                            <h5 class="mb-0 text-primary mt-1">@Model.FechaInicio.ToString("dd MMM yyyy")</h5>
                        </div>
                        <div class="col-6">
                            <small class="text-muted text-uppercase fw-bold">Total a Pagar</small>
                            <h5 class="mb-0 text-primary mt-1">$@Model.TotalAPagar.ToString("N0")</h5>
                        </div>
                    </div>
                </div>
                <div>
                    <a asp-action="Index" asp-controller="Sedes" class="btn btn-primary px-4 py-2 fw-bold rounded-pill shadow-sm">
                        Volver a Sedes
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
