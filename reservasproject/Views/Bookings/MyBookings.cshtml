@{
    ViewData["Title"] = "Mis Reservas";
}

<div class="container py-5">
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h1 class="fw-bold display-6 mb-1">Mis Reservas</h1>
            <p class="text-muted">Aquí puedes ver el historial completo de tus estadías pasadas y futuras.</p>
        </div>
        <div class="col-md-4 text-md-end">
            <a asp-controller="Sedes" asp-action="Index" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-circle"></i> Nueva Reserva
            </a>
        </div>
    </div>

    <!-- Contenedor donde JS inyectará las tarjetas -->
    <div id="placesGrid" class="row row-cols-1 row-cols-lg-2 g-4">
        <!-- Loader inicial -->
        <div class="col-12 text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando reservas...</span>
            </div>
            <p class="mt-3 text-muted">Cargando tus reservas...</p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/booking-ui.js"></script>
    <script src="~/js/booking-api.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            fetchMyBookings();
        });
    </script>
}
