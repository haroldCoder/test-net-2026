@{
    ViewData["Title"] = "Correo de Recuperación Enviado";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center mt-5">
        <h2 class="mb-4">@ViewData["Title"]</h2>
        <p class="lead">Si existe una cuenta asociada a ese correo, se ha enviado un enlace para restablecer la contraseña.</p>
        <p>Por favor revisa tu bandeja de entrada o la carpeta de spam.</p>
        <a asp-action="Login" class="btn btn-primary mt-3">Volver al Inicio de Sesión</a>
    </div>
</div>
